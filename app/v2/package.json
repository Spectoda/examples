{
  "name": "@spectoda/examples-app-v2",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun ./node_modules/vite/bin/vite.js --mode filesystem-v2 --host localhost --port 5305 --strictPort",
    "dev:filesystem": "bun ./node_modules/vite/bin/vite.js --mode filesystem-v2 --host localhost --port 5305 --strictPort",
    "dev:production": "bun ./node_modules/vite/bin/vite.js --mode filesystem-v2 --host localhost --port 5305 --strictPort",
    "build": "tsc -b && bun ./node_modules/vite/bin/vite.js build",
    "preview": "bun ./node_modules/vite/bin/vite.js preview --host localhost --port 5305 --strictPort"
  },
  "dependencies": {
    "dompurify": "^3.2.4",
    "marked": "^14.1.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.0"
  }
}
